# Elasticsearch
ES_HOST=elasticsearch
ES_PORT=9200
ES_INDEX=arxiv_papers
ES_JAVA_OPTS=-Xms2g -Xmx2g

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY_HEADER=X-API-Key
API_KEYS=changeme-key-1,changeme-key-2
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=20

# Ingestion
ARXIV_OAI_BASE_URL=http://export.arxiv.org/oai2
ARXIV_BULK_BASE_URL=https://arxiv.org/
INGESTION_BATCH_SIZE=500
INGESTION_INTERVAL_HOURS=6
SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Semantic Search
EMBEDDING_DIM=384

# Security
CORS_ORIGINS=*
MAX_QUERY_LENGTH=2000
MAX_REGEX_LENGTH=200
REGEX_TIMEOUT_MS=1000
